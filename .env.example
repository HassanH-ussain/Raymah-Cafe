PORT=3000
MONGO_URI=mongodb://localhost:27017/raymah-cafe
NODE_ENV=development

# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Nodemailer — SMTP credentials for order receipt emails
# Gmail: use an App Password (myaccount.google.com/apppasswords), not your login password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Raymah Café <you@gmail.com>

# Admin dashboard — set a strong random string (e.g. openssl rand -hex 32)
ADMIN_KEY=your-secret-admin-key

# CORS — set to your production domain when deploying (e.g. https://raymahcafe.com)
CORS_ORIGIN=http://localhost:3000
